<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">

    <Button
            android:text="Start"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/start_but"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/refresh_but"
            app:layout_constraintStart_toStartOf="@+id/guideline"/>
    <Button
            android:text="Stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/stop_but"
            app:layout_constraintTop_toBottomOf="@+id/start_but"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="@+id/guideline"/>

    <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:id="@+id/log_scrollView"
            app:layout_constraintTop_toBottomOf="@+id/save_conf_but"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintVertical_bias="0.0">
        <TextView
                android:text="log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/log_txtView"/>
    </ScrollView>
    <com.google.android.material.textfield.TextInputEditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="host" android:id="@+id/host"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline" android:layout_marginStart="8dp"
    />

    <com.google.android.material.textfield.TextInputEditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="port" android:id="@+id/port"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/host" app:layout_constraintEnd_toStartOf="@+id/guideline"
            android:layout_marginStart="8dp"/>
    <CheckBox
            android:text="Auto start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/auto_start_cb"
            app:layout_constraintTop_toBottomOf="@+id/port" app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp"/>
    <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:ems="10"
            android:id="@+id/instance_name_tt"
            app:layout_constraintTop_toBottomOf="@+id/auto_start_cb" app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp" android:hint="instance name"
            app:layout_constraintEnd_toStartOf="@+id/guideline"/>
    <Button
            android:text="Refresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/refresh_but"
            app:layout_constraintTop_toBottomOf="@+id/state_tv" app:layout_constraintStart_toStartOf="@+id/guideline"
            app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
            android:text="TextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/state_tv"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp" android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="@+id/guideline"/>
    <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/guideline"
            app:layout_constraintGuide_percent="0.75"/>
    <Button
            android:text="save"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/save_conf_but"
            app:layout_constraintTop_toBottomOf="@+id/stop_but" app:layout_constraintStart_toStartOf="@+id/guideline"
            app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>