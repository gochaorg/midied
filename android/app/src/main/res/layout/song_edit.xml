<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">
    <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            android:hint="имя файла" android:id="@+id/textInputLayout" app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
        />
    </com.google.android.material.textfield.TextInputLayout>
    <Button
            android:text="Продолжить"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/continue_rec_but"
            app:layout_constraintTop_toBottomOf="@+id/stop_rec_but"
            android:textAllCaps="false"
            app:layout_constraintStart_toStartOf="@+id/guideline2"
            app:layout_constraintEnd_toStartOf="@+id/guideline3"/>
    <Button
            android:text="Остановить"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/stop_rec_but"
            app:layout_constraintTop_toTopOf="@+id/start_rec_but"
            android:textAllCaps="false"
            app:layout_constraintEnd_toStartOf="@+id/guideline3"
            app:layout_constraintStart_toStartOf="@+id/guideline2"/>
    <Button
            android:text="Отправить"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/send_but"
            android:textAllCaps="false" app:layout_constraintTop_toTopOf="@+id/save_but"
            android:layout_marginTop="1dp"
            app:layout_constraintStart_toStartOf="@+id/guideline5" app:layout_constraintEnd_toEndOf="parent"/>
    <Button
            android:text="Сохранить"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/save_but"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/textInputLayout"
            app:layout_constraintStart_toStartOf="@+id/guideline2"
            android:textAllCaps="false"
            app:layout_constraintEnd_toStartOf="@+id/guideline3" app:layout_constraintHorizontal_bias="1.0"
    />
    <Button
            android:text="Запись"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/start_rec_but"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/save_but" app:layout_constraintStart_toStartOf="parent"
            android:textAllCaps="false" app:layout_constraintEnd_toStartOf="@+id/guideline6"
    />

    <Button
            android:text="Очистить"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/clear_rec_but"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guideline5"
            app:layout_constraintTop_toBottomOf="@+id/continue_rec_but" android:textAllCaps="false"/>
    <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/guideline2"
            app:layout_constraintGuide_percent="0.33"/>
    <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/guideline3"
            app:layout_constraintGuide_percent="0.6666667"/>
    <TextView
            android:text="Продолжительность 20 сек\nНоты 35: C#*10, D*2\nРитм 250мс, 500мс\nДинамика: 0.5..0.8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/song_summary"
            app:layout_constraintTop_toBottomOf="@+id/clear_rec_but"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
    />
    <ScrollView
            android:id="@+id/scroll_detail"
            android:layout_width="409dp"
            android:layout_height="625dp"
            app:layout_constraintTop_toBottomOf="@+id/song_summary" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" tools:ignore="InvalidId">
        <TextView
                android:text="[0мс.] C#4 / 0.5 / 250мс."
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/song_details" android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp" android:fontFamily="monospace"/>
    </ScrollView>
    <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/guideline5"
            app:layout_constraintGuide_percent="0.68613136"/>
    <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/guideline6"
            app:layout_constraintGuide_percent="0.31143552"/>
    <Button
            android:text="Воспроизвести"
            android:id="@+id/play_but"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toStartOf="@+id/guideline6" app:layout_constraintStart_toStartOf="parent"
            android:textAllCaps="false" app:layout_constraintTop_toTopOf="@+id/save_but"/>


</androidx.constraintlayout.widget.ConstraintLayout>